# Fuzzing dictionary for cel2sql
# This file contains common tokens that fuzzing should try

# CEL Operators
"=="
"!="
"<"
"<="
">"
">="
"&&"
"||"
"!"
"+"
"-"
"*"
"/"
"%"
"in"
"?"
":"

# CEL Functions
"startsWith"
"endsWith"
"contains"
"matches"
"size"
"all"
"exists"
"exists_one"
"filter"
"map"
"has"
"timestamp"
"duration"
"int"
"double"
"string"
"bool"
"bytes"

# CEL Keywords
"true"
"false"
"null"

# SQL Special Characters (potential injection vectors)
"'"
"\""
";"
"--"
"/*"
"*/"
"%"
"_"
"\\"
"\x00"
"\n"
"\r"
"\t"

# SQL Keywords (should be escaped)
"SELECT"
"INSERT"
"UPDATE"
"DELETE"
"DROP"
"CREATE"
"TABLE"
"WHERE"
"FROM"
"JOIN"
"UNION"
"OR"
"AND"
"NOT"

# Common Field Names
"name"
"email"
"age"
"price"
"active"
"created_at"
"updated_at"
"user"
"admin"
"password"

# Regex Patterns
"^"
"$"
"\\d"
"\\w"
"\\s"
"\\b"
"\\D"
"\\W"
"\\S"
"\\B"
"[a-z]"
"[A-Z]"
"[0-9]"
"[[:digit:]]"
"[[:alpha:]]"
"[[:alnum:]]"
"[[:space:]]"
"."
"*"
"+"
"?"
"{3}"
"{3,5}"
"()"
"|"
"(?i)"

# Unicode and Special Characters
"你好"
"🎉"
"é"
"ñ"
"ü"
"